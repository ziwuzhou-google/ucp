{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ucp.dev/schemas/common/types/loyalty.json",
  "title": "Loyalty",
  "description": "Container for loyalty memberships info.",
  "type": "object",
  "required": ["memberships"],
  "properties": {
    "memberships": {
      "type": "array",
      "items": { "$ref": "loyalty_membership.json" },
      "description": "List of memberships that the business offers or associated with.",
      "ucp_request": "omit"
    }
  }
}
